{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    // "@tarquinen/opencode-dcp@latest", // causes large GitHub API request counts — use manual /compact instead
    // "opencode-working-memory@latest",
    // "octto@latest",
    // "@forks.developing.today/octto@latest",
    // "micode@latest", // forces context7 MCP server with no opt-out: https://github.com/vtemian/micode/issues/49
    // "opencode-scheduler@latest",
    // "@openspoon/subtask2@latest",
    //"@tmegit/opencode-worktree-session@latest",
    "@mohak34/opencode-notifier@latest",
    "@plannotator/opencode@latest",
    "opencode-pty@latest",
    //"opencode-devcontainers@latest",
    // "opencode-dir",
    // "opencode-pilot@latest",
    "@franlol/opencode-md-table-formatter@latest",
    // "true-mem@latest",
    // "@knikolov/opencode-plugin-simple-memory@latest",
    // "opencode-mem@latest",
    "opencode-auto-continue@https://github.com/developing-today/opencode-auto-continue/archive/refs/tags/latest.tar.gz",
  ],
  "enabled_providers": ["github-copilot"],
  // "default_agent": "octto",
  "model": "github-copilot/gpt-5.6-sol",
  "small_model": "github-copilot/gpt-5.6-terra",
  "provider": {
    "github-copilot": {
      // Disable models per policy: any gpt < 5.6, any claude < 4.8, any gemini < 3.1.
      // Blacklist entries are exact upstream (models.dev) model ids; unknown ids are
      // harmless no-ops. Kept enabled: gpt-5.6-{sol,terra,luna}, claude-opus-4.8,
      // claude-fable-5, claude-sonnet-5, gemini-3.1-pro-preview, gemini-3.5-flash,
      // kimi-k2.7-code, mai-code-1-flash-picker.
      "blacklist": [
        // gpt < 5.6
        "gpt-4.1",
        "gpt-5-mini",
        "gpt-5.2",
        "gpt-5.2-codex",
        "gpt-5.3-codex",
        "gpt-5.4",
        "gpt-5.4-mini",
        "gpt-5.4-nano",
        "gpt-5.5",
        // claude < 4.8
        "claude-haiku-4.5",
        "claude-opus-4.5",
        "claude-opus-4.6",
        "claude-opus-4.7",
        "claude-sonnet-4",
        "claude-sonnet-4.5",
        "claude-sonnet-4.6",
        // gemini < 3.1
        "gemini-2.5-pro",
        "gemini-3-flash-preview",
      ],
      "models": {
        // ---------------------------------------------------------------
        // Added models: GitHub Copilot exposes these but the pinned opencode
        // (models.dev catalog) does not know them yet, so define them here.
        // Limits mirror OpenAI's published GPT-5.6 spec (1.05M ctx / 128k out),
        // matching how models.dev will list them once added upstream.
        // API ids: gpt-5.6-sol (alias gpt-5.6), gpt-5.6-terra, gpt-5.6-luna.
        // ---------------------------------------------------------------
        "gpt-5.6-sol": {
          "id": "gpt-5.6-sol",
          "name": "GPT-5.6 Sol",
          "family": "gpt",
          "release_date": "2026-07-09",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "limit": { "context": 1050000, "input": 272000, "output": 128000 },
        },
        "gpt-5.6-terra": {
          "id": "gpt-5.6-terra",
          "name": "GPT-5.6 Terra",
          "family": "gpt",
          "release_date": "2026-07-09",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "limit": { "context": 1050000, "input": 272000, "output": 128000 },
        },
        "gpt-5.6-luna": {
          "id": "gpt-5.6-luna",
          "name": "GPT-5.6 Luna",
          "family": "gpt",
          "release_date": "2026-07-09",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "limit": { "context": 1050000, "input": 272000, "output": 128000 },
        },
        // ---------------------------------------------------------------
        // Model-limit shaping DISABLED — use each model's upstream (models.dev)
        // limits. Kept commented for reference / easy re-enable. The trailing
        // comments are GitHub Copilot premium-request cost multipliers, not
        // opencode settings.
        // ---------------------------------------------------------------
        // "claude-haiku-4.5": {
        //   "limit": { "context": 200000, "output": 64000 }, // 0.33x
        // },
        // "claude-opus-4.5": {
        //   "limit": { "context": 200000, "output": 32000 }, // 3x
        // },
        // "claude-opus-4.6": {
        //   "limit": { "context": 200000, "output": 32000 }, // 3x
        // },
        // "claude-opus-4.7": {
        //   "limit": { "context": 200000, "output": 32000 },
        // },
        // "claude-opus-4.8": {
        //   "limit": { "context": 200000, "output": 32000 },
        // },
        // "claude-sonnet-4": {
        //   "limit": { "context": 216000, "output": 16000 }, // 1x
        // },
        // "claude-sonnet-4.5": {
        //   "limit": { "context": 200000, "output": 32000 }, // 1x
        // },
        // "claude-sonnet-4.6": {
        //   "limit": { "context": 200000, "output": 32000 }, // 1x
        // },
        // "gemini-2.5-pro": {
        //   "limit": { "context": 173000, "output": 64000 }, // 1x
        // },
        // "gemini-3-flash-preview": {
        //   "limit": { "context": 173000, "output": 64000 }, // 0.33x
        // },
        // "gemini-3-pro-preview": {
        //   "limit": { "context": 200000, "output": 64000 }, // 1x
        // },
        // "gemini-3.1-pro-preview": {
        //   "limit": { "context": 200000, "output": 64000 }, // 1x
        // },
        // "gpt-4.1": {
        //   "limit": { "context": 128000, "output": 16384 }, // 0x
        // },
        // "gpt-4o": {
        //   "limit": { "context": 128000, "output": 4096 }, // 0x
        // },
        // "gpt-5-mini": {
        //   "limit": { "context": 264000, "output": 64000 }, // 0x
        // },
        // "gpt-5.1": {
        //   "limit": { "context": 264000, "output": 64000 }, // 1x
        // },
        // "gpt-5.1-codex": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.1-codex-max": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.2": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.2-codex": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.3-codex": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.4": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "grok-code-fast-1": {
        //   "limit": { "context": 256000, "output": 64000 }, // 0.25x
        // },
      },
    },
  },
  // "agent": {
  // "build": {
  //   "mode": "subagent",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "plan": {
  //   "mode": "subagent",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "octto": {
  //   "variant": "thinking",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "bootstrapper": {
  //   "variant": "thinking",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "probe": {
  //   "variant": "thinking",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  //   "compaction": {
  //     "model": "github-copilot/gpt-5.4",
  //     "threshold": 0.5,
  //   },
  //   "title": {
  //     "model": "github-copilot/gpt-5.4",
  //   },
  //   "summary": {
  //     "model": "github-copilot/gpt-5.4",
  //   },
  // },
  "instructions": [
    ".opencode/instructions/lootbox.md",
    ".opencode/instructions/subagents.md",
  ],
  "compaction": {
    "reserved": 8192,
  },
}
