{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    // "@tarquinen/opencode-dcp@latest", // causes large GitHub API request counts — use manual /compact instead
    // "opencode-working-memory@latest",
    // "octto@latest",
    // "@forks.developing.today/octto@latest",
    // "micode@latest", // forces context7 MCP server with no opt-out: https://github.com/vtemian/micode/issues/49
    // "opencode-scheduler@latest",
    // "@openspoon/subtask2@latest",
    //"@tmegit/opencode-worktree-session@latest",
    "@mohak34/opencode-notifier@latest",
    "@plannotator/opencode@latest",
    "opencode-pty@latest",
    //"opencode-devcontainers@latest",
    // "opencode-dir",
    // "opencode-pilot@latest",
    "@franlol/opencode-md-table-formatter@latest",
    // "true-mem@latest",
    // "@knikolov/opencode-plugin-simple-memory@latest",
    // "opencode-mem@latest",
    "opencode-auto-continue@https://github.com/developing-today/opencode-auto-continue/archive/refs/tags/latest.tar.gz",
  ],
  "enabled_providers": ["github-copilot"],
  "default_agent": "build",
  "model": "github-copilot/gpt-5.6-sol",
  "small_model": "github-copilot/gpt-5.6-terra",
  "provider": {
    "github-copilot": {
      // Disable models per policy: any gpt < 5.6, any claude < 4.8, and all Gemini,
      // Kimi, and MAI models.
      // Blacklist entries are exact upstream (models.dev) model ids; unknown ids are
      // harmless no-ops. Kept enabled: gpt-5.6-{sol,terra,luna}, claude-fable-5,
      // and claude-sonnet-5.
      "blacklist": [
        // gpt < 5.6
        "gpt-4.1",
        "gpt-5-mini",
        "gpt-5.2",
        "gpt-5.2-codex",
        "gpt-5.3-codex",
        "gpt-5.4",
        "gpt-5.4-mini",
        "gpt-5.4-nano",
        "gpt-5.5",
        // claude < 4.8 (incl. opencode-generated `-fast` mode variants)
        "claude-haiku-4.5",
        "claude-opus-4.5",
        "claude-opus-4.6",
        "claude-opus-4.6-fast",
        "claude-opus-4.7",
        "claude-opus-4.7-fast",
        "claude-opus-4.8",
        "claude-opus-4.8-fast",
        "claude-sonnet-4",
        "claude-sonnet-4.5",
        "claude-sonnet-4.6",
        // gemini < 3.1
        "gemini-2.5-pro",
        "gemini-3-flash-preview",
        // disabled model families
        "gemini-3.1-pro-preview",
        "gemini-3.5-flash",
        "kimi-k2.7-code",
        "mai-code-1-flash-picker",
      ],
      "models": {
        // ---------------------------------------------------------------
        // Model-limit shaping DISABLED — use each model's upstream (models.dev)
        // limits. Kept commented for reference / easy re-enable. The trailing
        // comments are GitHub Copilot premium-request cost multipliers, not
        // opencode settings.
        // ---------------------------------------------------------------
        // "claude-haiku-4.5": {
        //   "limit": { "context": 200000, "output": 64000 }, // 0.33x
        // },
        // "claude-opus-4.5": {
        //   "limit": { "context": 200000, "output": 32000 }, // 3x
        // },
        // "claude-opus-4.6": {
        //   "limit": { "context": 200000, "output": 32000 }, // 3x
        // },
        // "claude-opus-4.7": {
        //   "limit": { "context": 200000, "output": 32000 },
        // },
        // "claude-opus-4.8": {
        //   "limit": { "context": 200000, "output": 32000 },
        // },
        // "claude-sonnet-4": {
        //   "limit": { "context": 216000, "output": 16000 }, // 1x
        // },
        // "claude-sonnet-4.5": {
        //   "limit": { "context": 200000, "output": 32000 }, // 1x
        // },
        // "claude-sonnet-4.6": {
        //   "limit": { "context": 200000, "output": 32000 }, // 1x
        // },
        // "gemini-2.5-pro": {
        //   "limit": { "context": 173000, "output": 64000 }, // 1x
        // },
        // "gemini-3-flash-preview": {
        //   "limit": { "context": 173000, "output": 64000 }, // 0.33x
        // },
        // "gemini-3-pro-preview": {
        //   "limit": { "context": 200000, "output": 64000 }, // 1x
        // },
        // "gemini-3.1-pro-preview": {
        //   "limit": { "context": 200000, "output": 64000 }, // 1x
        // },
        // "gpt-4.1": {
        //   "limit": { "context": 128000, "output": 16384 }, // 0x
        // },
        // "gpt-4o": {
        //   "limit": { "context": 128000, "output": 4096 }, // 0x
        // },
        // "gpt-5-mini": {
        //   "limit": { "context": 264000, "output": 64000 }, // 0x
        // },
        // "gpt-5.1": {
        //   "limit": { "context": 264000, "output": 64000 }, // 1x
        // },
        // "gpt-5.1-codex": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.1-codex-max": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.2": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.2-codex": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.3-codex": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "gpt-5.4": {
        //   "limit": { "context": 400000, "output": 128000 }, // 1x
        // },
        // "grok-code-fast-1": {
        //   "limit": { "context": 256000, "output": 64000 }, // 0.25x
        // },
      },
    },
  },
  "agent": {
    "build": {
      "model": "github-copilot/gpt-5.6-sol",
      "variant": "high",
    },
    "plan": {
      "model": "github-copilot/claude-fable-5",
      "variant": "high",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": {
          "*": "allow",
        },
      },
    },
    "general": {
      "model": "github-copilot/gpt-5.6-sol",
      "variant": "medium",
    },
    "explore": {
      "model": "github-copilot/gpt-5.6-sol",
      "variant": "medium",
    },
    "compaction": {
      "model": "github-copilot/gpt-5.6-sol",
      "variant": "medium",
    },
    "luna-medium": {
      "description": "Fast, low-cost worker for bounded utility tasks, extraction, formatting, and simple transformations. Relative capability 57/100; about 5s completion; about $0.39 per CursorBench task.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.6-luna",
      "variant": "medium",
    },
    // "terra-high": {
    //   "description": "Fast tool-heavy worker for codebase exploration, terminal tasks, and routine implementation. Relative capability 72/100; about 7s completion; about $0.89 per CursorBench task.",
    //   "mode": "primary",
    //   "model": "github-copilot/gpt-5.6-terra",
    //   "variant": "high",
    // },
    "sol-low": {
      "description": "Low-effort Sol subagent for quick, straightforward coding and research tasks.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.6-sol",
      "variant": "low",
    },
    "sol-medium": {
      "description": "Efficient strong coding worker for general implementation and debugging with low latency. Relative capability 80/100; about 14s completion; about $1.95 per CursorBench task.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.6-sol",
      "variant": "medium",
    },
    "sol-high": {
      "description": "Strong interactive coding worker for difficult debugging, terminal agents, and multi-step implementation. Relative capability 86/100; about 17s completion; about $2.79 per CursorBench task.",
      "mode": "subagent",
      "model": "github-copilot/gpt-5.6-sol",
      "variant": "high",
    },
    // "sol-xhigh": {
    //   "description": "Primary-only advanced reasoning agent for hard agentic tasks that need predictable sub-minute execution. Relative capability 94/100; about 39s completion; about $3.88 per CursorBench task.",
    //   "mode": "primary",
    //   "model": "github-copilot/gpt-5.6-sol",
    //   "variant": "xhigh",
    // },
    // "sol-max": {
    //   "description": "Primary-only maximum-effort Sol agent for frontier tasks where quality matters more than latency. Relative capability 98/100; about 135s completion; about $5.69 per CursorBench task.",
    //   "mode": "primary",
    //   "model": "github-copilot/gpt-5.6-sol",
    //   "variant": "max",
    // },
    "fable-low": {
      "description": "Fast frontier specialist for difficult repository bugs, diagnosis, and first-pass patch correctness. Relative capability 88/100; roughly 10-22s completion with variable latency; about $4.46 per CursorBench task.",
      "mode": "subagent",
      "model": "github-copilot/claude-fable-5",
      "variant": "low",
    },
    "fable-medium": {
      "description": "Frontier coding worker for hard multi-file engineering with balanced Fable cost and depth. Relative capability 92/100; roughly 12-43s completion with high variance; about $6.80 per CursorBench task.",
      "mode": "subagent",
      "model": "github-copilot/claude-fable-5",
      "variant": "medium",
    },
    // "fable-high": {
    //   "description": "Primary-only quality-first agent for architecture, migrations, difficult patches, and deep review. Relative capability 95/100; roughly 13-39s completion with variable latency; about $8.77 per CursorBench task.",
    //   "mode": "primary",
    //   "model": "github-copilot/claude-fable-5",
    //   "variant": "high",
    // },
    "title": {
      "model": "github-copilot/gpt-5.6-luna",
      "variant": "medium",
    },
    // Summary computes snapshot/file diffs without making an LLM call.
    // "summary": {},
  },
  // "agent": {
  // "build": {
  //   "mode": "subagent",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "plan": {
  //   "mode": "subagent",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "octto": {
  //   "variant": "thinking",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "bootstrapper": {
  //   "variant": "thinking",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  // "probe": {
  //   "variant": "thinking",
  //   "model": "github-copilot/claude-opus-4.8",
  // },
  //   "compaction": {
  //     "model": "github-copilot/gpt-5.4",
  //     "threshold": 0.5,
  //   },
  //   "title": {
  //     "model": "github-copilot/gpt-5.4",
  //   },
  //   "summary": {
  //     "model": "github-copilot/gpt-5.4",
  //   },
  // },
  "instructions": [
    "~/.config/opencode/instructions/lootbox.md",
    "~/.config/opencode/instructions/subagents.md",
  ],
  "compaction": {
    "reserved": 8192,
  },
}
