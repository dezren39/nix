--- a/packages/tui/src/routes/session/index.tsx
+++ b/packages/tui/src/routes/session/index.tsx
@@ -347,6 +347,23 @@ export function Session() {
   const dialog = useDialog()
   const renderer = useRenderer()
 
+  // Auto-follow (sticky-to-bottom) is only enabled while the user is within
+  // `auto_scroll_tolerance` lines of the bottom. Scrolling up (wheel or PgUp)
+  // disengages auto-follow so streamed output does not yank the viewport down;
+  // returning to within tolerance of the bottom re-engages it.
+  // Tolerance is configurable via tui config `auto_scroll_tolerance` (default 0 = must be exactly at bottom).
+  const autoScrollTolerance = createMemo(() => tuiConfig.auto_scroll_tolerance ?? 0)
+  const [stickToBottom, setStickToBottom] = createSignal(true)
+  const stickToBottomFrame = () => {
+    if (!scroll || scroll.isDestroyed) return
+    const maxScrollTop = Math.max(0, scroll.scrollHeight - scroll.viewport.height)
+    const atBottom = scroll.scrollTop >= maxScrollTop - autoScrollTolerance()
+    if (atBottom !== untrack(stickToBottom)) setStickToBottom(atBottom)
+  }
+  const stickToBottomCallback = async () => stickToBottomFrame()
+  renderer.setFrameCallback(stickToBottomCallback)
+  onCleanup(() => renderer.removeFrameCallback(stickToBottomCallback))
+
   event.on("session.status", (evt) => {
     if (evt.properties.sessionID !== route.sessionID) return
     if (evt.properties.status.type !== "retry") return
@@ -1178,7 +1195,7 @@ export function Session() {
                     foregroundColor: theme.border,
                   },
                 }}
-                stickyScroll={true}
