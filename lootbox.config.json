{
  "port": 9420,
  "serverUrl": "ws://127.0.0.1:9420/ws",
  "lootboxRoot": "/Users/drewry.pope/.config/nix/.lootbox",
  "mcpServers": {
    "codedb": {
      "command": "codedb",
      "args": ["mcp"],
      "env": {
        "CODEDB_NO_TELEMETRY": "1"
      }
    },
    "fff": {
      "command": "fff-mcp",
      "args": ["--no-update-check"]
    },
    "chrome-devtools": {
      "command": "chrome-devtools-mcp",
      "args": [
        "--headless",
        "--isolated",
        "--viewport=800x600",
        "--no-usage-statistics",
        "--no-performance-crux",
        "--no-category-emulation"
      ]
    },
    "context7": {
      "command": "mcp-remote",
      "args": ["https://mcp.context7.com/mcp"]
    }
  }
}
